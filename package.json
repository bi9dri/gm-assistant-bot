{
  "name": "gm-assistant-bot",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "lint": "bun --filter '*' lint",
    "format": "bun --filter '*' format",
    "typecheck": "bun --filter '*' typecheck",
    "dev": "bun --filter '*' dev",
    "build": "bun --filter '*' build",
    "deploy": "bun --filter gm-assistant-bot-backend deploy",
    "test": "bun --filter '*' test",
    "ncu": "ncu --packageManager bun --workspaces --cooldown 7",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "knip": "6.11.0",
    "npm-check-updates": "19.3.2",
    "oxfmt": "0.17.0",
    "oxlint": "1.32.0",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "6.0.3",
    "wrangler": "4.87.0"
  }
}